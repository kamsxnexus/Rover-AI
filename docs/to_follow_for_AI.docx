Sample Python Code for Deep Q-Learning (Light Version)

import random

import numpy as np

# Q-Table Initialization

actions = ['forward', 'left', 'right', 'stop']

q_table = {}

# Rover environment simulation (pseudo)

def get_state(sensor_data):

    return tuple(sensor_data)

def choose_action(state, epsilon=0.2):

    if random.uniform(0, 1) < epsilon:

        return random.choice(actions)  # Explore

    else:

        return max(q_table.get(state, {}), key=q_table.get(state, {}).get, default=random.choice(actions))  # Exploit

def update_q_table(state, action, reward, next_state, alpha=0.1, gamma=0.9):

    old_value = q_table.get(state, {}).get(action, 0)

    next_max = max(q_table.get(next_state, {}).values(), default=0)

    new_value = old_value + alpha * (reward + gamma * next_max - old_value)

    if state not in q_table:

        q_table[state] = {}

    q_table[state][action] = new_value

# Example Loop

for episode in range(1000):  # Training episodes

    state = get_state([0, 1])  # Example sensor input

    action = choose_action(state)

    # Simulate action: (update based on success/failure)

    reward = 10  # Assume success (you can create conditions based on collision)

    next_state = get_state([1, 0])  # Update next state

    update_q_table(state, action, reward, next_state)

